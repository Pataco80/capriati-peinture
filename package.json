    "gatsby-telemetry": "^1.3.38",
    "gatsby-transformer-json": "^2.4.15",
    "gatsby-transformer-sharp": "^2.5.20",
    "gsap": "^3.5.1",
    "polished": "^3.6.7",
    "prop-types": "^15.7.2",
    "react": "^17.0.1",
    "react-device-detect": "^1.15.0",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "react-parallax": "^3.1.2",
