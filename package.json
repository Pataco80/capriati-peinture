{
  "name": "gatsby-starter-hello-world",
  "private": true,
  "description": "A simplified bare-bones starter for Gatsby",
  "version": "0.1.0",
  "license": "0BSD",
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "preload-fonts": "gatsby-preload-fonts",
    "restart": "gatsby clean && gatsby develop"
  },
  "dependencies": {
    "@browniebroke/gatsby-image-gallery": "^4.0.0",
    "babel-plugin-styled-components": "^1.11.1",
    "dotenv": "^8.2.0",
    "gatsby": "^2.24.42",
    "gatsby-background-image": "^1.1.1",
    "gatsby-background-image-es5": "^1.1.1",
    "gatsby-image": "^2.4.15",
    "gatsby-plugin-manifest": "^2.4.22",
    "gatsby-plugin-offline": "^3.2.23",
    "gatsby-plugin-prefetch-google-fonts": "^1.4.3",
    "gatsby-plugin-preload-fonts": "^1.2.26",
    "gatsby-plugin-react-helmet": "^3.3.11",
    "gatsby-plugin-robots-txt": "^1.5.1",
    "gatsby-plugin-sharp": "^2.6.26",
    "gatsby-plugin-sitemap": "^2.4.11",
    "gatsby-plugin-styled-components": "^3.3.10",
    "gatsby-source-filesystem": "^2.3.24",
    "gatsby-telemetry": "^1.3.35",
    "gatsby-transformer-json": "^2.4.11",
    "gatsby-transformer-sharp": "^2.5.15",
    "polished": "^3.6.5",
    "prop-types": "^15.7.2",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-helmet": "^6.1.0",
    "styled-components": "^5.1.1",
    "styled-icons": "^10.16.0",
    "styled-media-query": "^2.1.2",
    "styled-reset": "^4.2.2"
  },
  "devDependencies": {
    "prettier": "2.0.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby-starter-hello-world"
  },
  "bugs": {
    "url": "https://github.com/gatsbyjs/gatsby/issues"
  }
}
