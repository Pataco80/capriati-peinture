    "gatsby-background-image": "^1.1.2",
    "gatsby-background-image-es5": "^1.1.2",
    "gatsby-image": "^2.4.21",
    "gatsby-plugin-alias-imports": "^1.0.5",
    "gatsby-plugin-google-fonts": "^1.0.1",
    "gatsby-plugin-htaccess": "^1.4.0",
    "gatsby-plugin-manifest": "^2.4.36",
    "gatsby-plugin-offline": "^3.5.0",
    "gatsby-plugin-preload-fonts": "^1.3.0",
    "gatsby-plugin-react-helmet": "^3.3.14",
